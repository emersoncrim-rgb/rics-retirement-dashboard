+        def _sector_rank_sell(trade) -> int:
+            """Rank SELL trades only: avoided first, liked last, neutral middle."""
+            tkr = str(getattr(trade, "ticker", "")).strip().upper()
+            sec = ticker_to_sector.get(tkr, "")
+            if sec in avoided:
+                return 0
+            if sec in liked:
+                return 2
+            return 1
+
+        # Only apply if we actually have overlap with liked/avoided sectors in the *proposed* trades.
+        overlap = False
+        for t in trades:
+            tkr = str(getattr(t, "ticker", "")).strip().upper()
+            sec = ticker_to_sector.get(tkr, "")
+            if sec in liked or sec in avoided:
+                overlap = True
+                break
+
+        if overlap:
+            # IMPORTANT: do NOT reorder BUY trades (especially CASH/MMF) or you'll break neutral ordering tests.
+            # We only reorder SELL trades, stably, and then put them back into their original positions.
+            sell_idxs = []
+            sells = []
+            for i, t in enumerate(trades):
+                if str(getattr(t, "action", "")).strip().lower() == "sell":
+                    sell_idxs.append(i)
+                    sells.append(t)
+
+            # Stable sort among sells:
+            # - avoided sells first
+            # - neutral sells next
+            # - liked sells last
+            # Tie-breaker: larger sells first within the same rank (keeps deterministic output)
+            sells.sort(
+                key=lambda t: (
+                    _sector_rank_sell(t),
+                    -float(getattr(t, "trade_value", 0) or 0.0),
+                )
+            )
+
