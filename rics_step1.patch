+def tab_your_plan():
+    """Tab 0: New landing page UI (calm, outcome-first)."""
+    st.header("Your Plan — Retirement health at a glance")
+    st.write("A simple summary of your retirement plan and three recommended actions.")
+
+    holdings = load_holdings_with_mode()
+
+    # Load supporting inputs (best-effort; this is a UI summary tab)
+    cashflow = []
+    recs = []
+    try:
+        cashflow = load_csv_rows(CASHFLOW_PATH)
+        tax_profile = load_json(TAX_PROFILE_PATH)
+        constraints = load_json(CONSTRAINTS_PATH)
+        rmd_divisors = load_json(RMD_DIVISORS_PATH)
+        recs = generate_all_recommendations(holdings, tax_profile, constraints, cashflow, rmd_divisors)
+    except Exception:
+        pass
+
+    # Status badge based on recommendation severity (UI-only: reassurance framing)
+    high_sev = sum(1 for r in recs if getattr(r, "severity", "") == "high")
+    med_sev = sum(1 for r in recs if getattr(r, "severity", "") == "medium")
+    if high_sev > 0:
+        status_badge = "🔴 Action recommended now"
+    elif med_sev > 0:
+        status_badge = "🟡 Small adjustments recommended"
+    else:
+        status_badge = "🟢 Your plan is on track"
+
+    st.subheader(status_badge)
+
+    # Cashflow summary (used for Income Coverage)
+    income_items = [c for c in cashflow if c.get("category") == "income"]
+    expense_items = [
+        c for c in cashflow
+        if c.get("category") == "expense" and c.get("frequency") == "annual"
+    ]
+    total_income = sum(float(i.get("amount", 0) or 0) for i in income_items)
+    total_exp = sum(float(e.get("amount", 0) or 0) for e in expense_items)
+    coverage = (total_income / total_exp) if total_exp > 0 else 0.0
+
+    # These are intentionally NOT fabricated. Show placeholders until model outputs exist.
+    funding_ratio_display = "—"
+    probability_display = "—"
+
+    st.write(
+        f"Funding ratio {funding_ratio_display} — at current withdrawal pace, your plan has a "
+        f"{probability_display} chance of lasting through expected lifetime."
+    )
+
+    with st.expander("Why this status?"):
+        st.write(
+            "This summary is designed to be simple. The status is driven by the highest-priority planning "
+            "flags currently found (if any). You can review details in Recommendations when you're ready."
+        )
+        st.write(
+            "Some advanced metrics (like funding ratio and success probability) will appear here once they "
+            "are available from the planning engine. For now, this page emphasizes clarity and next steps."
+        )
+
+    col1, col2, col3 = st.columns(3)
+    col1.metric("Funding Ratio", funding_ratio_display)
+    col2.metric("Success Probability", probability_display)
+    col3.metric("Income Coverage", f"{coverage:.2f}×" if total_exp > 0 else "—")
+
+    st.divider()
+    st.subheader("This year — income vs expenses")
+    st.write(
+        f"**Projected Income:** ${total_income:,.0f}   •   "
+        f"**Estimated Expenses:** ${total_exp:,.0f}   •   "
+        f"**Surplus / Shortfall:** ${total_income - total_exp:,.0f}"
+    )
+
+    st.divider()
+    st.subheader("Top 3 Actions")
+    if recs:
+        for idx, rec in enumerate(recs[:3], start=1):
+            title = getattr(rec, "title", f"Recommendation {idx}")
+            desc = getattr(rec, "description", "")
+            impact = getattr(rec, "impact_estimate", "")
+            st.markdown(f"**{idx}. {title}**")
+            if impact:
+                st.caption(impact)
+            if desc:
+                st.write(desc)
+            c1, c2, c3 = st.columns([1, 1, 6])
+            with c1:
+                st.button("Review", key=f"plan_review_{idx}")
+            with c2:
+                st.button("See details", key=f"plan_details_{idx}")
+            with c3:
+                st.write("")
+            st.divider()
+    else:
+        st.write("No urgent actions required.")
+
+    st.markdown("**Quick Links**")
+    q1, q2, q3, q4 = st.columns(4)
+    with q1:
+        st.button("View portfolio")
+    with q2:
+        st.button("Open cash flow plan")
+    with q3:
+        st.button("Tax details")
+    with q4:
+        st.button("Advanced tools")
